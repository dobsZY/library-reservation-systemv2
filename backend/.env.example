# ===========================================
# SELCUK UNIVERSITESI KUTUPHANE REZERVASYON
# Backend Environment Variables
# ===========================================

# Uygulama
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Veritabani (PostgreSQL)
# Yerel: asagidaki DB_*; opsiyonel tam URL (set edilirse uygulama buna gore baglanir)
# Uretim ornegi (docker agi, servis adi: postgres):
# DATABASE_URL=postgresql://kutuphane:kutuphane123@postgres:5432/kütüphane
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=library_user
DB_PASSWORD=library_pass_2025
DB_DATABASE=library_reservation

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT Authentication
JWT_SECRET=selcuk-university-library-jwt-secret-2025
JWT_EXPIRES_IN=7d

# QR Kod
QR_SECRET=selcuk-library-qr-secret-key

# Konum Dogrulama
LOCATION_MAX_DISTANCE_METERS=50
# GPS dogruluk kaynakli yalanci redleri azaltmak icin ust tolerans (metre)
LOCATION_ACCURACY_TOLERANCE_CAP_METERS=25

# Rezervasyon Kurallari
RESERVATION_MAX_HOURS=3
RESERVATION_MIN_HOURS=1
QR_TIMEOUT_MINUTES=30
QR_WARNING_MINUTES=25
CHAIN_QR_TIMEOUT_MINUTES=15
LOCK_RELEASE_DELAY_MINUTES=5

# Bildirimler (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=Kutuphane Rezervasyon API
SWAGGER_DESCRIPTION=Selcuk Universitesi Kutuphane Masa Rezervasyon Sistemi
SWAGGER_VERSION=1.0
