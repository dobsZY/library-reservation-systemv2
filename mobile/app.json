{
  "expo": {
    "name": "Selçuk Kütüphane",
    "slug": "selcuk-kutuphane",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "selcuk-kutuphane",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.selcuk.kutuphane",
      "infoPlist": {
        "NSCameraUsageDescription": "QR kod okutmak için kamera erişimi gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Masanıza yakın olduğunuzu doğrulamak için konum erişimi gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "edu.selcuk.kutuphane",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod okutmak için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Masanıza yakın olduğunuzu doğrulamak için konum erişimi gereklidir."
        }
      ],
      "expo-router"
    ]
  }
}
